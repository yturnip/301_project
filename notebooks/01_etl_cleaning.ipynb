    "import pandas as pd\n",
    "import sqlite3\n",
    "\n",
    "df = pd.read_csv('../data/clean/cleaned_data.csv')\n",
    "\n",
    "conn = sqlite3.connect('../database/students.db')\n",
    "\n",
    "df.to_sql('cleaned_data', conn, if_exists='replace', index=False)\n",
    "\n",
    "print(f\"Loaded {len(df)} rows into students.db\")\n",
    "\n",
    "conn.close()"
   ]
